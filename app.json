{
  "expo": {
    "name": "MarkerDetector",
    "slug": "MarkerDetector",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "plugins": [
      [
        "expo-asset",
        {
          "assets": [
            "assets/test-images/Marker1-TestImage1-Correct.jpg",
            "assets/test-images/Marker1-TestImage2-Correct.jpg",
            "assets/test-images/Marker1-TestImage3-Correct.jpg",
            "assets/test-images/Marker1-TestImage4-Incorrect.jpg",
            "assets/test-images/Marker1-TestImage5-Incorrect.jpg",
            "assets/test-images/Marker1-TestImage6-Incorrect.jpg",
            "assets/test-images/Marker1-TestImage7-Incorrect.jpg",
            "assets/test-images/Marker2-TestImage1-Correct.jpg",
            "assets/test-images/Marker2-TestImage2-Correct.jpg",
            "assets/test-images/Marker2-TestImage3-Correct.jpg",
            "assets/test-images/Marker2-TestImage4-Incorrect.jpg",
            "assets/test-images/Marker2-TestImage5-Incorrect.jpg",
            "assets/test-images/Marker2-TestImage6-Incorrect.jpg",
            "assets/test-images/Marker2-TestImage7-Incorrect.jpg",
            "assets/test-images/Marker1-Measurements.jpg",
            "assets/test-images/Marker2-Measurements.jpg"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MarkerDetector to access your camera to scan markers."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c4c25f5a-ec46-4f29-a42c-2e484184feff"
      }
    },
    "android": {
      "package": "com.soham041.MarkerDetector"
    }
  }
}
